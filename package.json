{
  "name": "@bardy-michael/portfolio",
  "version": "2.0.0",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev-https": "next dev --experimental-https --experimental-https-key ./certificates/localhost-key.pem --experimental-https-cert ./certificates/localhost.pem",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --quiet",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean:deps": "depcheck --config .depcheckrc",
    "clean:exports": "ts-prune",
    "clean:check": "npm-check",
    "clean:eslint": "eslint . --fix",
    "clean": "npm run clean:deps && npm run clean:exports && npm run clean:check && npm run clean:eslint",
    "postinstall": "node scripts/postinstall.mjs"
  },
