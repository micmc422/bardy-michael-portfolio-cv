    "@react-pdf/renderer": "^4.3.2",
    "@sparticuz/chromium-min": "^143.0.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/edge-config": "^1.4.3",
    "@wisp-cms/client": "^0.0.23",
    "chart.js": "^4.5.1",
    "classnames": "^2.5.1",
    "drizzle-orm": "^0.45.2",
    "google-auth-library": "^10.6.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-mdx-remote": "^6.0.0",
    "nodemailer": "^8.0.4",
    "open-graph-scraper": "^6.11.0",
    "prismjs": "^1.30.0",
    "puppeteer-core": "^24.40.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "sass": "^1.98.0",
    "sharp": "^0.34.5",
    "turndown": "^7.2.2",
    "web-push": "^3.6.7",
    "ws": "^8.20.0"
